{
  "name": "@cpn-console/playwright",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Our Playwright automated test suite",
  "keywords": [
    "playwright",
    "tests",
    "e2e"
  ],
  "main": "playwright.config.ts",
  "scripts": {
    "playwright:test": "pnpm exec playwright test",
    "playwright:test:ui": "pnpm exec playwright test --ui",
    "integ:playwright:test": "INTEGRATION=true pnpm exec playwright test",
    "integ:playwright:test:ui": "INTEGRATION=true pnpm exec playwright test --ui",
    "format": "eslint ./ --fix"
  },
  "devDependencies": {
    "@cpn-console/eslint-config": "workspace:^",
    "@cpn-console/ts-config": "workspace:^",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0"
  }
}
