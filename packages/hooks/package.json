{
  "name": "@cpn-console/hooks",
  "version": "4.1.0",
  "private": false,
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-pi-native/console"
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf ./dist ./types ./tsconfig.tsbuildinfo",
    "dev": "nodemon --watch src --ext .ts --exec 'vite-node src/config.ts'",
    "format": "eslint ./ --fix",
    "kube:e2e-ci": "echo 'check cache'",
    "lint": "eslint ./",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2e-ci": "echo 'check cache'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cpn-console/logger": "workspace:^",
    "@cpn-console/shared": "workspace:^",
    "json-schema": "^0.4.0",
    "vitest-mock-extended": "^2.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cpn-console/eslint-config": "workspace:^",
    "@cpn-console/ts-config": "workspace:^",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-algebra": "^2.0.0",
    "typescript": "^5.9.3",
    "undici-types": "^7.24.0",
    "vitest": "^4.1.5"
  }
}
