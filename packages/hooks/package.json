{
  "name": "@cpn-console/hooks",
  "type": "module",
  "version": "4.1.0",
  "private": false,
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-pi-native/console"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf ./dist ./types ./tsconfig.tsbuildinfo",
    "dev": "nodemon --watch src --ext .ts --exec 'vite-node src/config.ts'",
    "format": "eslint . --fix",
    "lint": "eslint .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@cpn-console/logger": "workspace:^",
    "@cpn-console/shared": "workspace:^",
    "json-schema": "^0.4.0",
    "vitest-mock-extended": "^2.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cpn-console/eslint-config": "workspace:^",
    "@cpn-console/ts-config": "workspace:^",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^2.1.9",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-algebra": "^2.0.0",
    "typescript": "^5.9.3",
    "undici-types": "^7.24.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest"
  }
}
