{
  "name": "@cpn-console/miracle",
  "type": "module",
  "version": "1.0.0",
  "private": false,
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-pi-native/console"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./keycloack": {
      "types": "./types/keycloack/index.d.ts",
      "default": "./dist/keycloack/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "keycloack": [
        "types/keycloack/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "node -e \"import('node:fs/promises').then(fs=>Promise.all([fs.rm('./dist',{recursive:true,force:true}),fs.rm('./types',{recursive:true,force:true}),fs.rm('./tsconfig.tsbuildinfo',{force:true})]))\"",
    "format": "eslint ./ --fix",
    "lint": "eslint ./"
  },
  "dependencies": {
    "@cpn-console/shared": "workspace:^",
    "@keycloak/keycloak-admin-client": "^26.5.5",
    "alchemy": "^0.90.1"
  },
  "devDependencies": {
    "@cpn-console/eslint-config": "workspace:^",
    "@cpn-console/ts-config": "workspace:^",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest"
  }
}
